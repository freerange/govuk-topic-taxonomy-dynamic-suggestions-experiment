<h1 class="govuk-heading-l">
  <%= @document.title %>
</h1>

<% if @document.govuk_url.present? %>
  <p class="govuk-body">
    <%= link_to "View document on GOV.UK (opens in new tab)", @document.govuk_url, class: "govuk-link", rel: "noreferrer noopener", target: "_blank" %>
  </p>
<% end %>

<h2 class="govuk-heading-m">Taxons</h2>

<% if @document.taxons.any? %>
  <ol class="govuk-list govuk-list--number">
    <% @document.taxons.each do |taxon| %>
      <% taxon = Taxon.find_by(base_path: taxon['base_path']) %>
      <li><%= render partial: 'taxons', locals: { taxon: } %></li>
    <% end %>
  </ol>
<% else %>
  <p class="govuk-body">The document has no taxons.</p>
<% end %>

<h2 class="govuk-heading-m">Suggested taxons</h2>

<% if @suggested_taxons.any? %>
  <ol class="govuk-list govuk-list--number">
    <% @suggested_taxons.each do |title, taxons| %>
      <% taxon = Taxon.find_by(base_path: taxons.first['base_path']) %>
      <li><%= render partial: 'taxons', locals: { taxon: } %></li>
    <% end %>
  </ol>
<% else %>
  <p class="govuk-body">There are no other suitable taxons.</p>
<% end %>

<h2 class="govuk-heading-m">Similar documents</h2>
<p class="govuk-body">These are the 5 documents most similar to the source document, from which we've derived the suggested taxons above.</p>

<ol class="govuk-list govuk-list--number">
  <% @similar_documents.each do |document| %>
    <li><%= link_to document.title, document_path(document), class: "govuk-link" %></li>
  <% end %>
</ol>
