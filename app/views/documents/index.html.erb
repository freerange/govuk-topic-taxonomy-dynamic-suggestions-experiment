<h2 class="govuk-heading-m">Documents</h2>

<p class="govuk-body"><%= link_to 'New document', new_document_path, class: "govuk-link" %></p>

<ul class="govuk-list govuk-list--bullet">
<% @documents.each do |document| %>
  <li><%= link_to document.title, document_path(document), class: "govuk-link" %></li>
<% end %>
</ul>
